<h1 class="text-center my-4">Payslips for Employee ID: <%= @employee_id %></h1>

<div class="container">
  <div class="row">
    <div class="col-md-12">
      <table class="table table-striped table-bordered table-hover">
        <thead class="thead-dark">
          <tr>
            <th>Pay Date</th>
            <th>Company</th>
            <th>Download</th>
          </tr>
        </thead>
        <tbody>
          <% @employee_payslips.each do |payslip| %>
            <tr>
              <td><%= Date.parse(payslip.pay_date).strftime("%B %d, %Y") rescue "Invalid Date" %></td>
              <td><%= payslip.company %></td>
              <td>
                <%= link_to 'Download PDF', download_payslip_pdf_path(filename: payslip.filename), class: 'btn btn-outline-success btn-sm text-white' %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<style>
  body {
    font-family: 'Arial', sans-serif;
    background-color: #f8f9fa;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: #333;
  }

  h1 {
    color: #007bff;
    font-size: 2rem;
  }

  .container {
    margin-top: 20px;
  }

  table {
    background-color: white;
    box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
    border-radius: 8px;
  }

  th, td {
    padding: 12px;
    text-align: center;
  }

  th {
    background-color: #343a40;
    color: white;
    font-weight: bold;
  }

  tr:nth-child(even) {
    background-color: #f2f2f2;
  }

  tr:hover {
    background-color: #e9ecef;
  }

  .btn {
    padding: 6px 12px;
    font-size: 14px;
    text-decoration: none;
    border-radius: 5px;
  }

  .btn:hover {
    opacity: 0.9;
  }
</style>
